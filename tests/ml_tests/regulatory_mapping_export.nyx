        { control: "GDPR Art. 32", desc: "Security of Processing", evidence: "privacy_enhancements.nyx", status: "PASS" },
        { control: "ISO 27001 (SoD)", desc: "Separation of Duties", evidence: "access_governance.nyx", status: "PASS" }
    ]

    export_mapping(mapping)
    
    println("")
    println("--- SUBMISSION METADATA ---")
