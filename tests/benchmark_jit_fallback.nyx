fn main() {
    let n = 10000000;
    let total = 0;
    let i = 0;

    let start = __native_time_ms();
    while i < n {
        // Complex conditional logic - Tier 1 (Symbolic) fails here.
        // Tier 2 (Aero-JIT) will compile this to native binary.
        if i % 2 == 0 {
            total = total + i;
        } else {
            total = total + (i * 2);
        }
        i = i + 1;
    }
    let end = __native_time_ms();

    println("Aero-JIT (Tier 2) Result: " + total);
    println("Aero-JIT (Tier 2) 10M iterations: " + (end - start) + "ms");
}
