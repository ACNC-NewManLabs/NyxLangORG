import std;
import ml;

fn generate_data(rows) {
    let ids = []
    let values = []
    let i = 0
    while i < rows {
        ids.push(i % 100) # 100 groups
        values.push((i * 1.0) / rows)
        i = i + 1
    }
    return {
        id: std::df::Column("id", "int", ids, null),
        val: std::df::Column("val", "float", values, null)
    }
}

fn benchmark_aggregation(rows) {
    println("Generating ", rows, " rows...")
    let cols = generate_data(rows)
    let df = std::df::DataFrame([cols.id, cols.val], null)
    
    println("--- Benchmarking ", rows, " rows ---")
    
    # Standard sum
    let start_sum = std::time::now()
    let val_col = df.col("val")
    let total_sum = val_col.sum()
    let end_sum = std::time::now()
    println("Sum: ", total_sum, " computed in ", (end_sum - start_sum) / 1000.0, " seconds")
    
    # GroupBy Aggregation (if available, else skip or simulate)
    # std::df doesn't currently expose a fast groupby string, but we can do a mean
    let start_mean = std::time::now()
    let mean_val = val_col.mean()
    let end_mean = std::time::now()
    println("Mean: ", mean_val, " computed in ", (end_mean - start_mean) / 1000.0, " seconds")

    println("Done.")
}

fn main() {
    println("=== DataFrame Aggregation Benchmarks ===")
    benchmark_aggregation(100000)   # 100K
    benchmark_aggregation(1000000)  # 1M
    benchmark_aggregation(5000000)  # 5M
}
