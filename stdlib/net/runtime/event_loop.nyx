/**
 * Check if a file descriptor is ready for writing
 */
fn check_write_ready(fd: i64) -> bool {
    return false;  // Placeholder
}

/**
 * Sort callbacks by priority
 */
fn sort_by_priority(callbacks: List<Callback>) -> List<Callback> {
    // Simple bubble sort for now
    let mut result = callbacks;
    let n = len(result);
    
    for i in range(0, n) {
        for j in range(0, n - i - 1) {
            if result[j].priority < result[j + 1].priority {
                let temp = result[j];
                result[j] = result[j + 1];
                result[j + 1] = temp;
            }
        }
    }
    
    return result;
}

/**
 * Count currently active tasks
 */
fn count_active_tasks() -> i64 {
    if global_loop != none {
        let loop_ref = global_loop as EventLoop;
        return loop_ref.active_tasks;
    }
    return 0;
}

/**
 * Get the global event loop instance
 */
fn get_loop() -> EventLoop? {
    return global_loop;
}

/**
 * Set the tick rate for the event loop
 */
fn set_tick_rate(ms: i64) {
    if global_loop != none {
        let loop_ref = global_loop as EventLoop;
        loop_ref.tick_rate = ms;
    }
}

/**
 * Check if the event loop is running
 */
fn is_running() -> bool {
    if global_loop != none {
        let loop_ref = global_loop as EventLoop;
        return loop_ref.running;
    }
    return false;
}
