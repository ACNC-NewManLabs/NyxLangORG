/**
 * Generate WebSocket main.nyx
 */
fn generate_ws_main() -> string {
    return '/**
 * WebSocket Server
 */
import net.websocket;

let ws = net.websocket.WebSocketServer(port: 8080);

ws.on_connect(fn(conn) {
    print("Client connected");
    
    conn.on_message(fn(msg) {
        print("Received: " + msg);
        // Echo back
        conn.send("Echo: " + msg);
    });
    
    conn.on_close(fn() {
        print("Client disconnected");
    });
});

print("WebSocket server starting on port 8080...");
ws.start();
';
}

