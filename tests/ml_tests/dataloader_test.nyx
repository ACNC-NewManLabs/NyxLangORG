import ml;

fn test_dataloader_basic() {
    println("--- DataLoader Basic Correctness ---")
    
    # 1. Create a simple dataset: [10, 2]
    let data = []
    let i = 0
    while i < 20 {
        data.push(i * 1.0)
        i = i + 1
    }
    let x = ml::tensor::Tensor(data, [10, 2], false)
    let y = ml::tensor::Tensor(data, [10, 2], false) # use same for simplicity
    
    let batch_size = 4
    let loader = ml::data::DataLoader(x, y, batch_size, false)
    
    # 2. Iterate through batches
    let count = 0
    let total_samples = 0
    
    let batch = loader.get_batch(loader)
    while batch != null {
        count = count + 1
        total_samples = total_samples + batch.x.shape[0]
        
        # Verify batch shape
        if count < 3 {
            if batch.x.shape[0] != 4 {
                println("FAIL: Expected batch size 4, got ", batch.x.shape[0])
                return
            }
        } else {
            if batch.x.shape[0] != 2 {
                println("FAIL: Expected last batch size 2, got ", batch.x.shape[0])
                return
            }
        }
        
        # Verify content (no shuffle, so it should be sequential)
        # First element of batch k should be (k * batch_size * 2)
        let expected_first = (count - 1) * batch_size * 2.0
        if batch.x.data[0] != expected_first {
            println("FAIL: Expected first element ", expected_first, " got ", batch.x.data[0])
            return
        }
        
        batch = loader.get_batch(loader)
    }
    
    if count != 3 {
        println("FAIL: Expected 3 batches, got ", count)
        return
    }
    
    if total_samples != 10 {
        println("FAIL: Expected 10 total samples, got ", total_samples)
        return
    }
    
    println("SUCCESS: Basic DataLoader verified")
}

fn test_dataloader_reset() {
    println("--- DataLoader Reset ---")
    let x = ml::tensor::randn([10, 2], false)
    let y = ml::tensor::randn([10, 1], false)
    let loader = ml::data::DataLoader(x, y, 5, false)
    
    # Exhaust once
    loader.get_batch(loader)
    loader.get_batch(loader)
    if loader.get_batch(loader) != null {
        println("FAIL: Loader should be exhausted")
        return
    }
    
    # Reset
    loader.reset(loader)
    let first_batch = loader.get_batch(loader)
    if first_batch == null {
        println("FAIL: Loader should have data after reset")
        return
    }
    if first_batch.x.shape[0] != 5 {
        println("FAIL: First batch after reset should be 5, got ", first_batch.x.shape[0])
        return
    }
    
    println("SUCCESS: DataLoader reset verified")
}

fn main() {
    test_dataloader_basic()
    test_dataloader_reset()
}
