fn FeatureCard(title: string, desc: string, icon: string) -> VNode {
    let card_style = Map::new()
    card_style.insert("background", "rgba(255, 255, 255, 0.02)")
    card_style.insert("border", "1px solid rgba(255, 255, 255, 0.05)")
    card_style.insert("border-radius", "28px")
    card_style.insert("padding", "3rem")
    card_style.insert("transition", "transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275)")

    let icon_style = Map::new()
    icon_style.insert("font-size", "3rem")
    icon_style.insert("margin-bottom", "1.5rem")

    let title_style = Map::new()
    title_style.insert("color", "white")
    title_style.insert("font-size", "1.6rem")
    title_style.insert("font-weight", "800")
    title_style.insert("margin-bottom", "1rem")
    title_style.insert("letter-spacing", "-0.02em")

    let p_style = Map::new()
    p_style.insert("color", "rgba(255, 255, 255, 0.55)")
    p_style.insert("font-size", "1.15rem")
    p_style.insert("line-height", "1.6")

    let card = VStack(card_style, [
        el("div", icon_style, [text_node(icon)]),
        el("h3", title_style, [text_node(title)]),
        el("p", p_style, [text_node(desc)])
    ])
    card.attrs.insert("class", "hover-lift") // For CSS hover effect
    return card
}

