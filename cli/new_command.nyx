 * Get character at index
 */
fn char_at(s: string, i: i64) -> string {
    // Would use native implementation
    return "";
}

// Native file system functions
fn __native_create_dir(path: string);
fn __native_write_file(path: string, content: string);
fn __native_file_exists(path: string) -> bool;

// Helper functions

fn starts_with(s: string, prefix: string) -> bool {
    if len(s) == 0 || len(prefix) == 0 {
        return false;
    }
    return substring(s, 0, len(prefix)) == prefix;
}

fn join(list: List<string>, delim: string) -> string {
    if len(list) == 0 {
        return "";
    }
    let result = list[0];
    let i = 1;
    while i < len(list) {
        result = result + delim + list[i];
        i = i + 1;
    }
    return result;
}

fn substring(s: string, start: i64, end: i64) -> string {
    if len(s) == 0 || start >= end || start >= len(s) {
        return "";
    }
    // Implementation would extract substring
    return s;
}

// Export
export {
    new_command,
    parse_new_args,
    print_new_help
};
