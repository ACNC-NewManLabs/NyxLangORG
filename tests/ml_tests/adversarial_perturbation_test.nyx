import ml;
import std::df;

# --- Helper: Adversarial Mock Model ---

fn predict_adversarial(val) {
    if val > 0.5 { return 1 }
    return 0
}

# --- Test Case ---

fn test_adversarial() {
    println("--- Testing Adversarial Perturbation (FGSM-style) ---")
    
    let base_input = 0.55 # Safely away from boundary
    let base_pred = predict_adversarial(base_input)
    println("Base input: ", base_input, " Pred: ", base_pred)
    
    # 1. Tiny perturbation (Attack)
    let epsilon = 0.01
    let perturbed_input = base_input - epsilon
    let perturbed_pred = predict_adversarial(perturbed_input)
    
    println("Perturbed input (-", epsilon, "): ", perturbed_input)
    println("  New Pred: ", perturbed_pred)
    
    if perturbed_pred != base_pred {
        println("SUCCESS: Adversarial attack flipped prediction with epsilon=", epsilon)
        println("FAIL: Model is fragile (Tiny nudge flips output)")
    } else {
        println("SUCCESS: Model is robust to tiny perturbations")
    }
}

fn main() {
    test_adversarial()
}
