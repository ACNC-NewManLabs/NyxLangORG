/**
 * CLI New Command
 * 
 * Provides CLI command for creating new Nyx projects:
 * - new: Create a new Nyx project from a template
 * 
 * @module cli::new_command
 */

/**
 * Project template types
 */
type Template = 
    | "web"           // Web application
    | "api"           // REST API
    | "websocket"     // WebSocket server
    | "microservice"  // Microservice
    | "cli"           // Command-line tool
    | "library"       // Library/package
    | "empty";        // Empty project

/**
 * Project structure to create
 */
type ProjectStructure = {
    name: string,
    template: string,
    directory: string,
    files: Map<string, string>
};

/**
 * Parse command line arguments for new command
 * 
 * @param args - Command line arguments
 * @returns Parsed options
 */
fn parse_new_args(args: List<string>) -> Map<string, any> {
    let options = {
        "name": "",
        "template": "web",
        "directory": ".",
        "force": false,
        "help": false
    };
    
    let i = 0;
    while i < args.length() {
        let arg = args[i];
        
        if arg == "--template" or arg == "-t" {
            if i + 1 < args.length() {
                options["template"] = args[i + 1];
                i = i + 1;
            }
        } else if arg == "--directory" or arg == "-d" {
            if i + 1 < args.length() {
                options["directory"] = args[i + 1];
                i = i + 1;
            }
        } else if arg == "--force" or arg == "-f" {
            options["force"] = true;
        } else if arg == "--help" or arg == "-h" {
            options["help"] = true;
        } else if !starts_with(arg, "-") && options["name"] == "" {
            options["name"] = arg;
        }
        
        i = i + 1;
    }
    
    return options;
}

/**
 * Print help for new command
 */
fn print_new_help() {
    print("Nyx New Command - Create a new Nyx project");
    print("");
    print("Usage:");
    print("  nyx new <project-name> [options]");
    print("");
    print("Options:");
    print("  -t, --template <type>    Project template (web, api, websocket, microservice, cli, library, empty)");
    print("  -d, --directory <dir>   Directory to create project in (default: current directory)");
    print("  -f, --force              Overwrite existing files");
    print("  -h, --help               Show this help message");
    print("");
    print("Templates:");
    print("  web           Web application with HTTP server");
    print("  api           REST API server");
    print("  websocket     Real-time WebSocket server");
    print("  microservice  Microservice template");
    print("  cli           Command-line tool");
    print("  library       Library/package");
    print("  empty         Empty project");
    print("");
    print("Examples:");
    print("  nyx new my-web-app");
    print("  nyx new my-api --template api");
    print("  nyx new my-app --directory ./projects");
}

/**
 * Generate project files based on template
 * 
 * @param name - Project name
 * @param template - Template type
 * @returns Map of file paths to contents
 */
fn generate_project(name: string, template: string) -> Map<string, string> {
    let files = {};
    
    // Project file
    files["nyxproject.json"] = generate_nyxproject(name, template);
    
    if template == "web" {
        files["src/main.nyx"] = generate_web_main();
        files["src/routes.nyx"] = generate_web_routes();
        files["public/index.html"] = generate_index_html(name);
        files["public/style.css"] = generate_style_css();
    } else if template == "api" {
        files["src/main.nyx"] = generate_api_main();
        files["src/handlers.nyx"] = generate_api_handlers();
    } else if template == "websocket" {
        files["src/main.nyx"] = generate_ws_main();
    } else if template == "microservice" {
        files["src/main.nyx"] = generate_microservice_main();
        files["src/config.nyx"] = generate_config();
    } else if template == "cli" {
        files["src/main.nyx"] = generate_cli_main();
    } else if template == "library" {
        files["src/lib.nyx"] = generate_lib();
    }
    
    return files;
}

/**
 * Generate nyxproject.json
 */
fn generate_nyxproject(name: string, template: string) -> string {
    return '{\n  "name": "' + name + '",\n  "version": "0.1.0",\n  "template": "' + template + '",\n  "dependencies": {}\n}';
}

/**
 * Generate web application main.nyx
 */
fn generate_web_main() -> string {
    return '/**
 * ' + 'Main application file
 */
import web;

let app = web.WebApp({
    "port": 8080,
    "static": "./public",
    "templates": "./templates"
});

// Import routes
import routes;

// Start server
app.start();
';
}

