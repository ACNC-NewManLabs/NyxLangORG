// --- GLOBAL SITE COMPOSER ---
fn App() {
    let global_style = Map::new()
    global_style.insert("background", "#0a0a0f")
    global_style.insert("min-height", "100vh")
    global_style.insert("font-family", "system-ui, -apple-system, sans-serif")
    global_style.insert("color", "white")
    global_style.insert("margin", "0")
    global_style.insert("padding", "0")
    global_style.insert("overflow-x", "hidden")

    let radial_glow = Map::new()
    radial_glow.insert("position", "absolute")
    radial_glow.insert("top", "-30%")
    radial_glow.insert("left", "-10%")
    radial_glow.insert("width", "120%")
    radial_glow.insert("height", "150%")
    radial_glow.insert("background", "radial-gradient(circle at center, rgba(0, 102, 255, 0.12) 0%, transparent 60%)")
    radial_glow.insert("z-index", "0")
    radial_glow.insert("pointer-events", "none")

    let content_layer = Map::new()
    content_layer.insert("position", "relative")
    content_layer.insert("z-index", "1")

    // Construct the massive DOM tree
    let view = VStack(global_style, [
        el("div", radial_glow, List::new()),
        VStack(content_layer, [
            NavBar(),
            HeroSection(),
            MetricsBanner(),
            FeaturesSection(),
            FullWidthCTA(),
            Footer()
        ])
    ])

    // Inject advanced CSS interactivity and animations that VNodes map to
    let style = `
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
        body { margin: 0; padding: 0; font-family: 'Inter', system-ui, sans-serif; background: #0a0a0f; color: white; -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
        ::-webkit-scrollbar { width: 12px; }
        ::-webkit-scrollbar-track { background: #050508; }
        ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 6px; border: 3px solid #050508; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }
        .hover-lift { transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .hover-lift:hover { transform: translateY(-12px); box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3); border-color: rgba(0, 242, 255, 0.2) !important; background: rgba(255, 255, 255, 0.04) !important; }
        a:hover { opacity: 0.8; }
    </style>
    `

    let html_head = "<!DOCTYPE html><html lang='en'><head><title>Nyx Native Experience</title><meta charset='utf-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'>" + style + "</head><body>"
    let html_body = render_node(view)
    let html_tail = "</body></html>"
    return html_head + html_body + html_tail
}

// --- ORIGINAL STDLIB API ENDPOINTS ---
// Leaving the actual web integration tests for routes compilation intact
// so the CLI still verifies the dependencies

fn get_user(ctx: Context) -> Response {
    let id = ctx.params.get("id")
    return api::ok(ctx, { "id": id, "name": "Nyx Massive Project User" })
}

fn main() {
    let config = server::default_config()
    config.host = "127.0.0.1"
    config.port = 9001
    config.workers = 4
    config.static_dir = "./public"
    
    let web_server = server::new_server(config)
    web_server.use(middleware::logging())
    web_server.use(middleware::cors())
    
    let app_router = router::new_router()
    app_router.get("/api/users/:id", get_user)
    web_server.use_router(app_router)
    
    console::log("Nyx Web Module Full Stack Backend: Listening on http://" + config.host + ":" + config.port.to_string())
    web_server.listen(config.host, config.port)
}
