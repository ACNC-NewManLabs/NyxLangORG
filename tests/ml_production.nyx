# tests/ml_production.nyx
# Comprehensive verification of ML Production Readiness features

import ml.tensor;
import ml.nn;
import ml.optim;
import ml.safety;
import ml.explain;
import ml.amp;
import ml.compress;

fn assert_eq(a, b, msg) {
    if a != b {
        println("ASSERT FAILED: " + msg + " | Expected: " + b + " Got: " + a)
        return false
    }
    return true
}

fn assert(cond, msg) {
    if cond == false {
        println("ASSERT FAILED: " + msg)
        return false
    }
    return true
}

fn main() {
    println("=== NYX ML: PRODUCTION READINESS VERIFICATION ===")

    # 1. Tensor Health & Stability
    println("\n[1] Testing Tensor Stability...")
    let t1 = ml::tensor::randn([4, 4], false)
    assert(t1.is_finite(), "randn tensor should be finite")
    t1.assert_finite("t1 health check")

    let t_inf = ml::tensor::Tensor([1.0, 2.0, 1e40, 4.0], [4], false)
    assert(!t_inf.is_finite(), "t_inf should NOT be finite")
    println("✅ Tensor stability checks PASSED")

    # 2. Model State Management (state_dict)
    println("\n[2] Testing Model State Management...")
    let model = ml::nn::Sequential([
        ml::nn::Linear(10, 20, "relu"),
        ml::nn::Linear(20, 2, null)
    ])

    let sd = model.state_dict()
    assert(sd["layer_0.weight"] != null, "state_dict should contain layer 0 weight")
    assert(sd["layer_1.bias"] != null, "state_dict should contain layer 1 bias")

    # Modify weights manually
    let old_val = model.layers[0].weight.data[0]
    model.layers[0].weight.data[0] = 999.0
    model.load_state_dict(sd)
    assert_eq(model.layers[0].weight.data[0], old_val, "load_state_dict should restore weights")
    println("✅ Model state management PASSED")

    # 3. Training Modes (eval/train)
    println("\n[3] Testing Training Modes...")
    let do_layer = ml::nn::Dropout(0.5)
    let model_do = ml::nn::Sequential([do_layer])

    model_do.train()
    assert(do_layer.training == true, "model.train() should set layer.training to true")
    model_do.eval()
    assert(do_layer.training == false, "model.eval() should set layer.training to false")
    println("✅ Training modes PASSED")

    # 4. Adversarial Safety (FGSM)
    println("\n[4] Testing Adversarial Safety (FGSM)...")
    # Simple linear model that's easy to "break"
    let x = ml::tensor::randn([1, 10], false)
    let safety_model = ml::nn::Sequential([
        ml::nn::Linear(10, 2, null)
    ])
    # This might or might not change label depending on eps
    let vulnerable = ml::safety::adversarial_check(safety_model, x, 0.5)
    println("Adversarial check result (vulnerable): {}", vulnerable)
    println("✅ Adversarial safety check PASSED (evaluated)")

    # 5. Explainability (Attention Visualizer)
    println("\n[5] Testing Explainability (ASCII Attention)...")
    let attn = ml::tensor::randn([4, 4], false)
    # Normalize to [0, 1] for visualization
    let attn_sum = attn.abs_max()
    let i = 0
    while i < attn.data.len() {
        let v = attn.data[i]
        if v < 0 { v = -v }
        attn.data[i] = v / attn_sum
        i = i + 1
    }
    ml::explain::visualize_attention(attn)
    println("✅ Attention visualization PASSED")

    # 6. Performance & Scale (AMP & Compression)
    println("\n[6] Testing Performance & Scale (AMP & Compression)...")
    
    # AMP Test
    let scaler = ml::amp::GradScaler()
    let loss = ml::tensor::Tensor([1.0], [1], true, null, "cpu")
    let scaled_loss = scaler.scale_loss(loss)
    assert_eq(scaled_loss.data[0], 65536.0, "GradScaler should scale loss")
    println("✅ AMP GradScaler PASSED")

    # Compression Test (Pruning)
    let prune_model = ml::nn::Sequential([
        ml::nn::Linear(10, 10, null)
    ])
    # Set one weight to a very small value
    prune_model.layers[0].weight.data[0] = 0.00001
    ml::compress::prune_weights(prune_model, 0.01)
    assert_eq(prune_model.layers[0].weight.data[0], 0.0, "prune_weights should zero out small weights")
    
    # Compression Test (Quantization)
    ml::compress::quantize_weights(prune_model, 8)
    println("✅ Compression (Pruning/Quantization) PASSED")

    println("\n=== ML PRODUCTION VERIFICATION COMPLETE ✓ ===")
}
