fn LayerNorm(normalized_shape, eps) {
    if eps == null { eps = 1e-5 }
    # Assume normalized_shape is a single int for simplicity in most common cases (channels)
    let size = 1
    if std::meta::typeof(normalized_shape) == "List" {
        let i = 0
        while i < normalized_shape.len() {
            size = size * normalized_shape[i]
            i = i + 1
        }
    } else {
        size = normalized_shape
    }
    
    let gamma = randn([size], true)
    let beta = zeros([size], true)
    
    return {
        type: "LayerNorm",
        gamma: gamma,
        beta: beta,
        eps: eps,
        forward: fn(self, x) {
            return x.layer_norm(self.gamma, self.beta, self.eps)
        }
    }
}

fn AdaptiveAvgPool2d(out_h, out_w) {
    return {
        type: "AdaptiveAvgPool2d",
