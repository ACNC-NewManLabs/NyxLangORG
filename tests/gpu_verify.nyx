# GPU Acceleration Verification (wgpu)
# Compares CPU vs GPU MatMul for a high-dimensional task

fn main() {
    println("--- Nyx GPU Acceleration Verification ---")

    let dim = 128
    println("Initializing matrices of dimension {}x{}...", dim, dim)

    # 1. CPU Reference
    let cpu_model = ml::nn::Linear(dim, dim, "relu", "cpu")
    let x_cpu = ml::tensor::randn([dim, dim], false, "cpu")
    
    let start_cpu = get_time()
    let out_cpu = cpu_model.forward(x_cpu)
    let end_cpu = get_time()
    println("CPU Forward took: {}ms", (end_cpu - start_cpu) * 1000)

    # 2. GPU Acceleration
    # Copy weights to GPU if needed (our current implementation handles transfer per op)
    let gpu_model = ml::nn::Linear(dim, dim, "relu", "gpu")
    let x_gpu = ml::tensor::randn([dim, dim], false, "gpu")
    
    # Warm-up (wgpu initialization)
    println("Initializing wgpu compute pipeline...")
    gpu_model.forward(x_gpu)
    
    let start_gpu = get_time()
    let out_gpu = gpu_model.forward(x_gpu)
    let end_gpu = get_time()
    println("GPU Forward took: {}ms", (end_gpu - start_gpu) * 1000)

    # 3. Verification
    println("Output Shape: {}", out_gpu.shape)
    if out_gpu.shape[0] == dim && out_gpu.shape[1] == dim {
        println("SUCCESS: GPU MatMul produced correct output shape.")
    } else {
        println("FAILURE: Incorrect output shape!")
    }

    # Verify a few samples
    println("CPU Sample [0,0]: {}", out_cpu.data[0])
    println("GPU Sample [0,0]: {}", out_gpu.data[0])
    
    println("\n--- Phase 10: GPU Hardening Verified ---")
}
