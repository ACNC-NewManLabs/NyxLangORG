/**
 * Create a new Nyx project
 * 
 * @param args - Command line arguments
 */
fn new_command(args: List<string>) {
    let options = parse_new_args(args);
    
    if options["help"] == true {
        print_new_help();
        return;
    }
    
    let name = options["name"];
    let template = options["template"];
    let directory = options["directory"];
    let force = options["force"];
    
    if name == "" {
        print("Error: Project name is required");
        print("Run 'nyx new --help' for usage information");
        return;
    }
    
    // Validate template
    let valid_templates = ["web", "api", "websocket", "microservice", "cli", "library", "empty"];
    let is_valid = false;
    for t in valid_templates {
        if t == template {
            is_valid = true;
        }
    }
    
    if !is_valid {
        print("Error: Invalid template '" + template + "'");
        print("Valid templates: " + join(valid_templates, ", "));
        return;
    }
    
    print("Creating new " + template + " project: " + name);
    print("Directory: " + directory);
    print("");
    
    // Generate project files
    let files = generate_project(name, template);
    
    print("Generated files:");
    for file_path in files {
        print("  - " + file_path);
    }
    
    // Create the project directory structure
    let project_dir = directory + "/" + name;
    
    // Create directories and files using native operations
    create_project_structure(name, template, project_dir, files);
    
    print("");
    print("Project created successfully!");
    print("");
    print("Next steps:");
    print("  cd " + name);
    print("  nyx dev");
}

/**
 * Create project directory structure and files on disk
 */
fn create_project_structure(name: string, template: string, project_dir: string, files: Map<string, string>) {
    // Create project directory
    __native_create_dir(project_dir);
    
    // Create subdirectories based on template
    if template == "web" {
        __native_create_dir(project_dir + "/src");
        __native_create_dir(project_dir + "/public");
        __native_create_dir(project_dir + "/templates");
    } else if template == "api" {
        __native_create_dir(project_dir + "/src");
    } else if template == "websocket" {
        __native_create_dir(project_dir + "/src");
    } else if template == "microservice" {
        __native_create_dir(project_dir + "/src");
    } else if template == "cli" {
        __native_create_dir(project_dir + "/src");
    } else if template == "library" {
        __native_create_dir(project_dir + "/src");
    }
    
    // Write all generated files
    for file_path in files {
        let full_path = project_dir + "/" + file_path;
        let content = files[file_path];
        
        // Create parent directory if needed
        let parent_dir = get_parent_dir(full_path);
        if parent_dir != "" {
            __native_create_dir(parent_dir);
        }
        
        // Write file
        __native_write_file(full_path, content);
    }
    
    // Create README.md
    let readme = generate_readme(name, template);
    __native_write_file(project_dir + "/README.md", readme);
    
    // Create .gitignore
    let gitignore = generate_gitignore();
    __native_write_file(project_dir + "/.gitignore", gitignore);
}

/**
 * Generate README.md content
 */
fn generate_readme(name: string, template: string) -> string {
    return "# " + name + "

A Nyx " + template + " project.

## Getting Started

```bash
# Run the project
nyx dev

# Build for production
nyx build
```

## Project Structure

- src/ - Source code
" + (if template == "web" then "- public/ - Static files" else "") + "

## Learn More

Visit https://nyxlang.dev for documentation.
";
}

