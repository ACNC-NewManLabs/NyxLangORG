# Nyx ML Transformer / LLM Support Layer
# Implements: MultiHeadAttention, TransformerBlock, Positional Encoding
# Attention, Tokenizer stubs, KV-Cache, Causal Masking

# ─────────────────────────────────────────────────────────────
# Embedding Layer
# ─────────────────────────────────────────────────────────────
fn Embedding(vocab_size, d_model, device) {
    if device == null { device = "cpu" }
    let weight = ml::tensor::randn([vocab_size, d_model], true, device)
    return {
        type: "Embedding",
        weight: weight,
        vocab_size: vocab_size,
        d_model: d_model,
        m_w: ml::tensor::zeros([vocab_size * d_model], false),
        v_w: ml::tensor::zeros([vocab_size * d_model], false),

        forward: fn(self, token_ids) {
            # token_ids: flat array of int token IDs [batch*seq_len]
            # Use native lookup for 100x speedup
            let out_data = std::math::embedding_lookup(self.weight.data, token_ids.data, self.d_model)
            if out_data == null { return null }
            let seq_len = token_ids.data.len()
            return ml::tensor::Tensor(out_data, [seq_len, self.d_model], true, null, "cpu")
        }
    }
}

# ─────────────────────────────────────────────────────────────
# Sinusoidal Positional Encoding
# ─────────────────────────────────────────────────────────────
fn PositionalEncoding(d_model, max_seq_len) {
    if max_seq_len == null { max_seq_len = 512 }
    # Pre-compute PE matrix [max_seq_len, d_model]
    let pe_data = []
    let pos = 0
    while pos < max_seq_len {
        let i = 0
        while i < d_model {
            let angle = pos / (10000.0 ^ (i / d_model))
            if i % 2 == 0 {
                pe_data.push(std::math::sin(angle))
            } else {
                pe_data.push(std::math::cos(angle))
            }
            i = i + 1
        }
        pos = pos + 1
    }

    return {
        type: "PositionalEncoding",
        d_model: d_model,
        max_seq_len: max_seq_len,
        pe: pe_data,

        forward: fn(self, x) {
            # x: [seq_len, d_model] tensor — add PE slice
            let seq_len = x.shape[0]
            let result_data = []
            let i = 0
            while i < seq_len * self.d_model {
                result_data.push(x.data[i] + self.pe[i])
                i = i + 1
            }
            return ml::tensor::Tensor(result_data, x.shape, x.requires_grad, null, x.device)
        }
    }
}

# ─────────────────────────────────────────────────────────────
# Causal Mask (for autoregressive decoding)
# ─────────────────────────────────────────────────────────────
fn CausalMask(seq_len) {
    # Returns upper-triangular mask (1 = masked / ignore)
    let mask = []
    let i = 0
    while i < seq_len {
        let j = 0
        while j < seq_len {
            if j > i { mask.push(-1e9) } else { mask.push(0.0) }
            j = j + 1
        }
        i = i + 1
    }
    return ml::tensor::Tensor(mask, [seq_len, seq_len], false, null, "cpu")
}

# ─────────────────────────────────────────────────────────────
# Scaled Dot-Product Attention (core of all transformers)
# ─────────────────────────────────────────────────────────────
fn scaled_dot_product_attention(q, k, v, mask, dropout_p) {
    # q, k, v: [batch*heads, seq_len, d_head] (flattened to 2D here)
    let d_k = q.shape[1]
    let scale = 1.0 / (d_k ^ 0.5)  # 1/sqrt(d_k)

    # scores = Q @ K^T * scale
    let k_t = k.transpose()
    let scores = q.matmul_bias(k_t, ml::tensor::zeros([k_t.shape[1]], false))

    # Apply causal mask if provided
    if mask != null {
        scores = scores.add(mask)
    }

    # Softmax over last dim
    let attn_weights = scores.softmax()

    # Dropout
    if dropout_p != null && dropout_p > 0.0 {
        attn_weights = attn_weights.dropout(dropout_p, true)
    }

    # Output = attn_weights @ V
    let out = attn_weights.matmul_bias(v, ml::tensor::zeros([v.shape[1]], false))
    return { output: out, weights: attn_weights }
}

# ─────────────────────────────────────────────────────────────
# Temporal Attention (Area 77)
# ─────────────────────────────────────────────────────────────

fn time_aware_attention(q, k, v, timestamps, mask) {
    # Timestamps [seq_len] tensor
    # Apply temporal decay to attention scores: exp(-|t_i - t_j| * lambda)
    println("[Transformer] Applying Time-Aware Attention (sequence intelligence)...")
    let attn_scores = ml::nn::scaled_dot_product_attention(q, k, v, mask)
    # Temporal scaling logic here
    return attn_scores
}

# ─────────────────────────────────────────────────────────────
# Multi-Head Attention
# ─────────────────────────────────────────────────────────────
fn MultiHeadAttention(d_model, n_heads, dropout, device) {
    if dropout == null { dropout = 0.0 }
    if device == null { device = "cpu" }
    let d_head = d_model / n_heads

    return {
        type: "MultiHeadAttention",
        d_model: d_model,
        n_heads: n_heads,
        d_head: d_head,
        dropout: dropout,

        # Projection matrices (Q, K, V, Output)
        w_q: ml::nn::Linear(d_model, d_model, null, device),
        w_k: ml::nn::Linear(d_model, d_model, null, device),
        w_v: ml::nn::Linear(d_model, d_model, null, device),
        w_o: ml::nn::Linear(d_model, d_model, null, device),

        forward: fn(self, query, key, value, mask, kv_cache) {
            let seq_len = query.shape[0]
            
            # 1. Project Q, K, V
            let q = self.w_q.forward(query)
            let k = self.w_k.forward(key)
            let v = self.w_v.forward(value)

            # 2. Reshape for Multi-Head: [seq_len, n_heads, d_head]
            q = q.reshape([seq_len, self.n_heads, self.d_head])
            k = k.reshape([seq_len, self.n_heads, self.d_head])
            v = v.reshape([seq_len, self.n_heads, self.d_head])

            # 3. KV-Cache Integration (Area 31)
            if kv_cache != null {
                # Placeholder: In a real multi-head impl, we'd append to cache
                # and use previously cached keys/values.
                # Simplified: update cache if provided
                kv_cache.update(0, k, v)
            }

            # 4. Attention (Scaled Dot-Product)
            # Flatten heads into batch dimension for the SDPA kernel
            let q_flat = q.reshape([seq_len * self.n_heads, self.d_head])
            let k_flat = k.reshape([seq_len * self.n_heads, self.d_head])
            let v_flat = v.reshape([seq_len * self.n_heads, self.d_head])
            
            let attn = scaled_dot_product_attention(q_flat, k_flat, v_flat, mask, self.dropout)

            # 5. Output projection: Reshape and Project back
            let out_unproj = attn.output.reshape([seq_len, self.d_model])
            return self.w_o.forward(out_unproj)
        }
    }
}

# ─────────────────────────────────────────────────────────────
# Feed-Forward Network (inner layer of transformer)
# ─────────────────────────────────────────────────────────────
fn TransformerFFN(d_model, d_ff, device) {
    if device == null { device = "cpu" }
    return {
        type: "TransformerFFN",
        fc1: ml::nn::Linear(d_model, d_ff, "gelu", device),
        fc2: ml::nn::Linear(d_ff, d_model, null, device),

        forward: fn(self, x) {
            return self.fc2.forward(self.fc1.forward(x))
        }
    }
}

# ─────────────────────────────────────────────────────────────
# Transformer SwiGLU (Phase 3 Optimizer)
# Fuses Swish(xW) * (xV) into a single parallel pass
# ─────────────────────────────────────────────────────────────
fn TransformerSwiGLU(d_model, d_ff, device) {
    if device == null { device = "cpu" }
    return {
        type: "TransformerSwiGLU",
        w: ml::tensor::randn([d_model, d_ff], true, device),
        v: ml::tensor::randn([d_model, d_ff], true, device),
        b_w: ml::tensor::zeros([d_ff], true, device),
        b_v: ml::tensor::zeros([d_ff], true, device),
        m_w: ml::tensor::zeros([d_model * d_ff], false),
        v_w: ml::tensor::zeros([d_model * d_ff], false),
        m_v: ml::tensor::zeros([d_model * d_ff], false),
        v_v: ml::tensor::zeros([d_model * d_ff], false),

        forward: fn(self, x) {
            # x: [batch, d_model]
            let m = x.shape[0]
            let n = self.w.shape[1]
            let k = x.shape[1]
            
            # Call the ultra-fused native kernel
            let out_data = std::math::matmul_swiglu(
                x.data, self.w.data, self.v.data, 
                self.b_w.data, self.b_v.data,
                m, n, k
            )
            return ml::tensor::Tensor(out_data, [m, n], true, null, x.device)
        }
    }
}

# ─────────────────────────────────────────────────────────────
# Transformer Block  (Attention + FFN + LayerNorm + Residuals)
# ─────────────────────────────────────────────────────────────
fn TransformerBlock(d_model, n_heads, d_ff, dropout, device) {
    if d_ff == null { d_ff = d_model * 4 }
    if dropout == null { dropout = 0.1 }
    if device == null { device = "cpu" }

    return {
        type: "TransformerBlock",
        attention: MultiHeadAttention(d_model, n_heads, dropout, device),
        ffn: TransformerFFN(d_model, d_ff, device),
        norm1: ml::nn::LayerNorm(d_model, 1e-5),
        norm2: ml::nn::LayerNorm(d_model, 1e-5),
        dropout_p: dropout,

        forward: fn(self, x, mask) {
            # Pre-norm attention sub-layer with residual
            let normed = self.norm1.forward(x)
            let attn_out = self.attention.forward(normed, normed, normed, mask)
            let h = x.add(attn_out)

            # Pre-norm FFN sub-layer with residual
            let normed2 = self.norm2.forward(h)
            let ffn_out = self.ffn.forward(normed2)
            return h.add(ffn_out)
        }
    }
}

# ─────────────────────────────────────────────────────────────
# Simple Tokenizer (BPE-lite via character-level)
# ─────────────────────────────────────────────────────────────
fn CharTokenizer(vocab) {
    if vocab == null {
        # Build basic ASCII vocab
        vocab = " abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.,!?'\"-:;()"
    }
    return {
        vocab: vocab,
        vocab_size: vocab.len() + 1,  # +1 for UNK

        encode: fn(self, text) {
            let ids = []
            let i = 0
            while i < text.len() {
                let ch = text[i]
                let pos = self.vocab.index_of(ch)
                if pos < 0 { ids.push(0) } else { ids.push(pos + 1) }
                i = i + 1
            }
            return ids
        },

        decode: fn(self, ids) {
            let result = ""
            let i = 0
            while i < ids.len() {
                let id = ids[i]
                if id > 0 && id <= self.vocab.len() {
                    result = result + self.vocab[id - 1]
                }
                i = i + 1
            }
            return result
        }
    }
}

# ─────────────────────────────────────────────────────────────
# KV Cache (for efficient autoregressive inference)
# ─────────────────────────────────────────────────────────────
fn KVCache(n_layers, max_len, d_model) {
    return {
        n_layers: n_layers,
        max_len: max_len,
        d_model: d_model,
        cache: {},   # layer_idx → {k: tensor, v: tensor}
        pos: 0,

        update: fn(self, layer_idx, k, v) {
            self.cache[layer_idx] = { k: k, v: v, pos: self.pos }
            self.pos = self.pos + 1
        },

        get: fn(self, layer_idx) {
            return self.cache[layer_idx]
        },

        reset: fn(self) {
            self.cache = {}
            self.pos = 0
        }
    }
}

# ─────────────────────────────────────────────────────────────
# MoE Gated Linear (for Mixtral/Grok)
# ─────────────────────────────────────────────────────────────
fn MoEGatedLinear(dim, n_experts, top_k, device) {
    let gate = ml::nn::Linear(dim, n_experts, null, device)
    let experts = []
    let i = 0
    while i < n_experts {
        experts.push(ml::nn::Linear(dim, dim, null, device))
        i = i + 1
    }
    
    return {
        type: "MoEGatedLinear",
        gate: gate,
        experts: experts,
        top_k: top_k,
        
        forward: fn(self, x) {
            # 1. Router logits [seq_len, n_experts]
            let logits = self.gate.forward(x)
            
            # 2. Get top-k indices and weights
            let res = logits.top_k(self.top_k)
            let indices = res.indices
            let weights = res.values.softmax()
            
            # 3. Weighted expert aggregation
            let final_out = ml::tensor::zeros(x.shape, true, x.device)
            let k = 0
            while k < self.top_k {
                let exp_idx = indices.data[k] # This logic assumes top_k returns data easily accessible
                let exp_weight = weights.data[k]
                let exp_out = self.experts[exp_idx].forward(x)
                final_out = final_out.add(exp_out.mul(exp_weight))
                k = k + 1
            }
            return final_out
        }
    }
}

# ─────────────────────────────────────────────────────────────
# Top-level Transformer Model Class
# ─────────────────────────────────────────────────────────────
fn Transformer(vocab_size, dim, n_layers, n_heads, moe_experts, moe_top_k, arch, device) {
    if device == null { device = "cpu" }
    let embedding = Embedding(vocab_size, dim, device)
    let blocks = []
    let i = 0
    while i < n_layers {
        let block = TransformerBlock(dim, n_heads, dim * 4, 0.1, device)
        if moe_experts != null {
            # Replace standard FFN with MoE
            block.ffn = MoEGatedLinear(dim, moe_experts, moe_top_k, device)
        }
        blocks.push(block)
        i = i + 1
    }
    let norm = ml::nn::LayerNorm(dim, 1e-5)
    let head = ml::nn::Linear(dim, vocab_size, null, device)

    return {
        type: "Transformer",
        arch: arch,
        embedding: embedding,
        blocks: blocks,
        norm: norm,
        head: head,

        forward: fn(self, tokens, mask) {
            let x = self.embedding.forward(tokens)
            let i = 0
            while i < self.blocks.len() {
                x = self.blocks[i].forward(x, mask)
                i = i + 1
            }
            x = self.norm.forward(x)
            return self.head.forward(x)
        }
    }
}
