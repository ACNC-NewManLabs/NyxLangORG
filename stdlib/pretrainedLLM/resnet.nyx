use ml::nn;

fn create(config) {
    return ml::nn::Sequential([
        ml::nn::Conv2D(3, 64, 7, 2, 3),
        ml::nn::BatchNorm2d(64),
        ml::nn::ReLU(),
        ml::nn::MaxPool2D(3, 2),
        ml::nn::AdaptiveAvgPool2d(1, 1),
        ml::nn::Flatten(),
        ml::nn::Linear(2048, 1000, null, "cpu")
    ]);
}
