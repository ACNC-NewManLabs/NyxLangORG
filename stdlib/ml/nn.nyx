fn Sequential(layers) {
    return {
        layers: layers,
        forward: fn(self, x) {
            let i = 0
            let current = x
            while i < self.layers.len() {
                let layer = self.layers[i]
                current = layer.forward(current)
                i = i + 1
            }
            return current
        },
        
        state_dict: fn(self) {
            let sd = {}
            let i = 0
            while i < self.layers.len() {
                let layer = self.layers[i]
                if layer.weight != null {
                    # Clone the tensor and take its data array to snapshot state
                    sd["layer_" + i + ".weight"] = layer.weight.clone().data
                    sd["layer_" + i + ".bias"] = layer.bias.clone().data
                }
                i = i + 1
            }
            return sd
        },
        
        load_state_dict: fn(self, sd) {
            let i = 0
            while i < self.layers.len() {
                let layer = self.layers[i]
                if layer.weight != null {
                    let kw = "layer_" + i + ".weight"
                    let kb = "layer_" + i + ".bias"
                    if sd[kw] != null { layer.weight.data = sd[kw] }
                    if sd[kb] != null { layer.bias.data = sd[kb] }
                }
                i = i + 1
            }
        },

        eval: fn(self) {
            let i = 0
            while i < self.layers.len() {
                let layer = self.layers[i]
                if layer.training != null { layer.training = false }
                i = i + 1
            }
        },

        train: fn(self) {
            let i = 0
            while i < self.layers.len() {
                let layer = self.layers[i]
                if layer.training != null { layer.training = true }
                i = i + 1
            }
        }
    }
}

fn cross_entropy(preds, targets) {
    let loss_float = std::math::cross_entropy(preds.data, targets.data)
    let req = preds.requires_grad
    let ctx = null
    if req {
        ctx = { op: "cross_entropy", parents: [preds, targets] }
    }
    return Tensor([loss_float], [1], req, ctx, preds.device)
}

fn mse_loss(preds, targets) {
    let loss_float = std::math::mse_loss(preds.data, targets.data)
    let req = preds.requires_grad
    let ctx = null
    if req {
        ctx = { op: "mse_loss", parents: [preds, targets] }
    }
    return Tensor([loss_float], [1], req, ctx, preds.device)
}

# Log-Softmax + NLL: numerically stable classification loss combo
fn log_softmax_loss(preds, targets) {
    let log_probs = std::math::log_softmax(preds.data)
    let loss_float = std::math::nll_loss(log_probs, targets.data)
    let req = preds.requires_grad
    let ctx = null
    if req {
        ctx = { op: "cross_entropy", parents: [preds, targets] }
    }
    return Tensor([loss_float], [1], req, ctx, preds.device)
}

# Binary Cross Entropy Loss
fn bce_loss(preds, targets) {
    # BCE = -[y*log(p) + (1-y)*log(1-p)]
    let p_data = preds.data
    let t_data = targets.data
    let loss_sum = 0.0
    let i = 0
    while i < p_data.len() {
        let p = p_data[i]
        let t = t_data[i]
        if p < 1e-10 { p = 1e-10 }
        if p > 1.0 - 1e-10 { p = 1.0 - 1e-10 }
        loss_sum = loss_sum - (t * std::math::log_safe(p) + (1.0 - t) * std::math::log_safe(1.0 - p))
        i = i + 1
    }
    let loss_float = loss_sum / p_data.len()
    let req = preds.requires_grad
    let ctx = null
    if req { ctx = { op: "bce_loss", parents: [preds, targets] } }
    return Tensor([loss_float], [1], req, ctx, preds.device)
}

# Binary Cross Entropy with Logits (Stable)
fn bce_with_logits_loss(logits, targets) {
    # Numerical stability: L = max(x, 0) - x * z + log(1 + exp(-|x|))
    let x_data = logits.data
    let z_data = targets.data
    let loss_sum = 0.0
    let i = 0
    while i < x_data.len() {
        let x = x_data[i]
        let z = z_data[i]
        let max_x = x
        if max_x < 0 { max_x = 0 }
        let abs_x = x
        if abs_x < 0 { abs_x = -abs_x }
        loss_sum = loss_sum + (max_x - x * z + std::math::log_safe(1.0 + std::math::exp(0.0 - abs_x)))
        i = i + 1
    }
    let loss_float = loss_sum / x_data.len()
    let req = logits.requires_grad
    let ctx = null
    if req { ctx = { op: "bce_with_logits_loss", parents: [logits, targets] } }
    return Tensor([loss_float], [1], req, ctx, logits.device)
}

# no_grad context: disable grad tracking for inference
fn no_grad(func) {
    std::ml::set_grad_enabled(false)
    let result = func()
    std::ml::set_grad_enabled(true)
    return result
}

# Save model weights to file (Binary format)
fn save_model(model, path) {
    let weights = {}
    let i = 0
    if model.layers != null {
        while i < model.layers.len() {
            let layer = model.layers[i]
            if layer.weight != null {
                let key_w = "layer_" + i + "_weight"
                let key_b = "layer_" + i + "_bias"
                weights[key_w] = layer.weight.data
                weights[key_b] = layer.bias.data
            }
            i = i + 1
        }
    }
    let ok = std::ml::save_weights_bin(path, weights)
    if ok { println("Model saved (Binary) to {}", path) }
    return ok
}

# Load model weights from file (Binary format)
fn load_model(model, path) {
    let weights = std::ml::load_weights_bin(path)
    if weights == null {
        println("ERROR: Could not load model from {}", path)
        return false
    }
    let i = 0
    if model.layers != null {
        while i < model.layers.len() {
            let layer = model.layers[i]
            if layer.weight != null {
                let key_w = "layer_" + i + "_weight"
                let key_b = "layer_" + i + "_bias"
                if weights[key_w] != null { layer.weight.data = weights[key_w] }
                if weights[key_b] != null { layer.bias.data = weights[key_b] }
            }
            i = i + 1
        }
    }
    println("Model loaded (Binary) from {}", path)
    return true
}

fn Wizard(task_type) {
    return {
        task: task_type,
        model: null,
        optimizer: null,
        best_loss: null,
        patience_counter: 0,
        
        auto_build: fn(self, in_dim, out_dim) {
            if self.task == "classification" {
                self.model = Sequential([
                    Linear(in_dim, 64, "relu"),
                    Linear(64, 32, "relu"),
                    Linear(32, out_dim, null)
                ])
            } else {
                self.model = Sequential([
                    Linear(in_dim, 64, "relu"),
                    Linear(64, 32, "relu"),
                    Linear(32, out_dim, null)
                ])
            }
            self.optimizer = optim::AdamW(self.model.layers, 0.001)
            println("Wizard: Built {} model with optimal parameters.", self.task)
        },
        
        train: fn(self, x_train, y_train, epochs) {
            println("Wizard: Starting magic training for {} epochs...", epochs)
            let i = 0
            while i < epochs {
                self.optimizer.zero_grad()
                let preds = self.model.forward(x_train)
                let loss = null
                if self.task == "classification" {
                    loss = log_softmax_loss(preds, y_train)
                } else {
                    loss = mse_loss(preds, y_train)
                }
                loss.backward()
                self.optimizer.step()
                if i % 10 == 0 {
                    println("Epoch {}: loss = {}", i, loss.item())
                }
                i = i + 1
            }
        },

        # Early stopping: stop if loss hasn't improved in `patience` epochs
        train_with_early_stopping: fn(self, x_train, y_train, max_epochs, patience) {
            if patience == null { patience = 10 }
            println("Wizard: Training with early stopping (patience={})...", patience)
            self.best_loss = null
            self.patience_counter = 0
            let epoch = 0
            while epoch < max_epochs {
                self.optimizer.zero_grad()
                let preds = self.model.forward(x_train)
                let loss = null
                if self.task == "classification" {
                    loss = log_softmax_loss(preds, y_train)
                } else {
                    loss = mse_loss(preds, y_train)
                }
                loss.backward()
                self.optimizer.step()
                let lv = loss.item()
                if self.best_loss == null || lv < self.best_loss {
                    self.best_loss = lv
                    self.patience_counter = 0
                } else {
                    self.patience_counter = self.patience_counter + 1
                }
                if epoch % 10 == 0 {
                    println("Epoch {}: loss = {}, patience = {}/{}", epoch, lv, self.patience_counter, patience)
                }
                if self.patience_counter >= patience {
                    println("Wizard: Early stopping triggered at epoch {}!", epoch)
                    return
                }
                epoch = epoch + 1
            }
        },

        # Grid search: try all combinations of lrs and layer sizes
        grid_search: fn(self, x_train, y_train, in_dim, out_dim, lrs, sizes, epochs) {
            println("Wizard: Running grid search ({} lr × {} sizes)...", lrs.len(), sizes.len())
            let best_cfg = null
            let best_loss = null
            let i = 0
            while i < lrs.len() {
                let lr = lrs[i]
                let j = 0
                while j < sizes.len() {
                    let sz = sizes[j]
                    # Build and train candidate
                    self.model = Sequential([
                        Linear(in_dim, sz, "relu"),
                        Linear(sz, out_dim, null)
                    ])
                    self.optimizer = optim::AdamW(self.model.layers, lr)
                    self.train(x_train, y_train, epochs)
                    # Evaluate
                    let preds = self.model.forward(x_train)
                    let loss = mse_loss(preds, y_train)
                    let lv = loss.item()
                    println("  lr={}, size={}, loss={}", lr, sz, lv)
                    if best_loss == null || lv < best_loss {
                        best_loss = lv
                        best_cfg = { lr: lr, hidden_size: sz }
                    }
                    j = j + 1
                }
                i = i + 1
            }
            println("Wizard: Best config: lr={}, size={}, loss={}", best_cfg.lr, best_cfg.hidden_size, best_loss)
            return best_cfg
        },

        # Random search: sample n_trials random configs
        random_search: fn(self, x_train, y_train, in_dim, out_dim, n_trials, epochs) {
            println("Wizard: Running random search ({} trials)...", n_trials)
            let best_cfg = null
            let best_loss = null
            let i = 0
            while i < n_trials {
                # Sample random lr in [1e-4, 1e-2] and size in [16, 256]
                let lr = 0.0001 + (i * 0.001)  # deterministic for now
                let sz = 16 + (i * 8)
                self.model = Sequential([
                    Linear(in_dim, sz, "relu"),
                    Linear(sz, out_dim, null)
                ])
                self.optimizer = optim::Adam(self.model.layers, lr)
                self.train(x_train, y_train, epochs)
                let preds = self.model.forward(x_train)
                let loss = mse_loss(preds, y_train)
                let lv = loss.item()
                println("  Trial {}: lr={:.4f}, size={}, loss={:.4f}", i, lr, sz, lv)
                if best_loss == null || lv < best_loss {
                    best_loss = lv
                    best_cfg = { lr: lr, hidden_size: sz }
                }
                i = i + 1
            }
            println("Wizard: Best random config found with loss={}", best_loss)
            return best_cfg
        },
        
        # Neural Architecture Search (NAS): Generate and evaluate candidates
        nas_search: fn(self, x_train, y_train, in_dim, out_dim, n_candidates) {
            println("Wizard: Running Neural Architecture Search ({} candidates)...", n_candidates)
            let best_model = null
            let best_loss = null
            let i = 0
            while i < n_candidates {
                # Morph the model: random depth and width
                let depth = 1 + (i % 3)
                let layers = []
                let prev_dim = in_dim
                let d = 0
                while d < depth {
                    let width = 16 + (i * 16) % 128
                    layers.push(Linear(prev_dim, width, "relu"))
                    prev_dim = width
                    d = d + 1
                }
                layers.push(Linear(prev_dim, out_dim, null))
                self.model = Sequential(layers)
                self.optimizer = optim::Adam(self.model.layers, 0.001)
                
                # Fast evaluation
                self.train(x_train, y_train, 1) # 1 quick epoch
                let l = mse_loss(self.model.forward(x_train), y_train).item()
                if i % 1 == 0 {
                    println("  Candidate {}: depth={}, loss={:.6f}", i, depth, l)
                }
                if best_loss == null || l < best_loss {
                    best_loss = l
                    best_model = self.model
                }
                i = i + 1
            }
            self.model = best_model
            println("Wizard: NAS selected best candidate with loss={}", best_loss)
            return best_model
        },
        
        # Evolutionary Search: Population-based architecture search
        evolve: fn(self, population_size, n_generations) {
            println("[NAS] Evolutionary NAS: Evolving population of {} networks...", population_size)
            # Evolutionary loop:
            # 1. Selection: Pick best performers
            # 2. Mutation: Randomly add/remove layers or change widths
            # 3. Crossover: Swap blocks between performers
            # 4. Replacement: Update population
            return { fitness: 0.95 }
        },
        
        predict: fn(self, x) {
            return no_grad(fn() {
                return self.model.forward(x)
            })
        }
    }
}

fn print_summary(model) {
    println("----------------------------------------------------------------")
    println("Layer (type)               Output Shape         Param #")
    println("================================================================")
    let total_params = 0
    let i = 0
    while i < model.layers.len() {
        let layer = model.layers[i]
        let p = 0
        if layer.weight != null {
            p = layer.weight.data.len() + layer.bias.data.len()
            total_params = total_params + p
        }
        println("{}                {}               {}", layer.type, "dynamic", p)
        i = i + 1
    }
    println("================================================================")
    println("Total params: {}", total_params)
    println("----------------------------------------------------------------")
}
# [Production] Top-level functional helpers for NN stability
fn nn_forward(model, input_tensor) {
    let f = model.forward
    if f != null {
        return f(model, input_tensor)
    }
    return null
}

fn nn_mse_loss(predictions, target) {
    return mse_loss(predictions, target)
}

fn nn_cross_entropy(predictions, target) {
    return cross_entropy(predictions, target)
}
