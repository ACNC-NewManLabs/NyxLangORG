# Nyx Standard Library: NN Layers
# Modular neural network components accelerated by Rust
# Note: tensor.nyx is co-loaded in the same engine - no import needed

fn Linear(in_features, out_features, activation, device) {
    # Initialize with Kaiming/Xavier-like randoms
    let weight = seeded_randn([in_features, out_features], true, device)
    let bias = zeros([out_features], true, device)
    
    return {
        type: "Linear",
        weight: weight,
        bias: bias,
        activation: activation,
        
        # Optimizer state (for Adam)
        m_w: zeros([in_features * out_features]),
        v_w: zeros([in_features * out_features]),
        m_b: zeros([out_features]),
        v_b: zeros([out_features]),
        
        forward: fn(self, input_tensor) {
            if self.device == "gpu" {
                if self.activation == "relu" {
                    # Use fused GPU kernel: input, m, k, weight, n, bias
                    let res = std::math::matmul_bias_relu_gpu(
                        input_tensor.data, input_tensor.shape[0], input_tensor.shape[1],
                        self.weight.data, self.weight.shape[1], self.bias.data
                    )
                    if res != null {
                        let req = input_tensor.requires_grad || self.weight.requires_grad || self.bias.requires_grad
                        let ctx = null
                        if req { ctx = { op: "matmul_bias_relu_gpu", parents: [input_tensor, self.weight, self.bias] } }
                        return ml::tensor::Tensor(res, [input_tensor.shape[0], self.weight.shape[1]], req, ctx, "gpu")
                    }
                }
                
                # Fallback or other activations
                let h = input_tensor.matmul_gpu(self.weight)
                let res = h.add(self.bias)
                if self.activation == "sigmoid" { return res.sigmoid() }
                if self.activation == "tanh" { return res.tanh() }
                return res
            }

            if self.activation == "relu" {
                let res_data = std::math::matmul_bias_relu(input_tensor.data, input_tensor.shape, self.weight.data, self.weight.shape, self.bias.data)
                if res_data == null { return null }
                let out_shape = [input_tensor.shape[0], self.weight.shape[1]]
                let req = false
                if input_tensor.requires_grad { req = true }
                if self.weight.requires_grad { req = true }
                if self.bias.requires_grad { req = true }
                let ctx = null
                if req {
                    ctx = { op: "matmul_bias_relu", parents: [input_tensor, self.weight, self.bias] }
                }
                return ml::tensor::Tensor(res_data, out_shape, req, ctx)
            }

            let h = input_tensor.matmul_bias(self.weight, self.bias)
            if h == null { return null }
            
            if self.activation == "relu" {
                return h.relu()
            }
            if self.activation == "leaky_relu" {
                return h.leaky_relu(0.01)
            }
            if self.activation == "elu" {
                return h.elu(1.0)
            }
            if self.activation == "gelu" {
                return h.gelu()
            }
            if self.activation == "hardswish" {
                return h.hardswish()
            }
            if self.activation == "mish" {
                return h.mish()
            }
            if self.activation == "sigmoid" {
                return h.sigmoid()
            }
            if self.activation == "tanh" {
                return h.tanh()
            }
            return h
        }
    }
}

# Quantized Linear layer for production inference
# Uses Int8-simulated precision (scaling float to -127..127)
fn QuantizedLinear(in_features, out_features, activation) {
    let weight = randn([in_features, out_features])
    let bias = zeros([out_features])
    
    return {
        type: "QuantizedLinear",
        weight: weight,
        bias: bias,
        activation: activation,
        scale_w: 1.0,
        
        quantize: fn(self) {
            # Find max absolute value for scaling
            let max_val = 0.0
            let i = 0
            while i < self.weight.data.len() {
                let v = self.weight.data[i]
                if v < 0 { v = -v }
                if v > max_val { max_val = v }
                i = i + 1
            }
            self.scale_w = max_val / 127.0
            # Simulating int8 storage by rounding to multiples of scale
            let quantized_data = []
            for v in self.weight.data {
                quantized_data.push(v / self.scale_w)
            }
            # Use native rounding for performance and correctness
            let rounded = std::math::round(quantized_data)
            let i = 0
            while i < self.weight.data.len() {
                self.weight.data[i] = rounded[i] * self.scale_w
                i = i + 1
            }
            println("Quantized Linear layer: weight scale = {}", self.scale_w)
        },
        
        forward: fn(self, x) {
            # In a real engine, this would use integer matmul
            return x.matmul_bias(self.weight, self.bias).relu()
        }
    }
}

fn check_model_health(model) {
    let result = { ok: true, report: [] }
    let i = 0
    if model.layers != null {
        while i < model.layers.len() {
            let layer = model.layers[i]
            if layer.weight != null {
                let j = 0
                let nans = 0
                while j < layer.weight.data.len() {
                    let v = layer.weight.data[j]
                    if v != v { nans = nans + 1 } # NaN check
                    j = j + 1
                }
                if nans > 0 {
                    result.ok = false
                    result.report.push("Layer " + i + " (" + layer.type + ") has " + nans + " NaNs!")
                }
            }
            i = i + 1
        }
    }
    return result
}

fn BatchNorm2d(num_features, eps, device) {
    if eps == null { eps = 1e-5 }
    let weight = randn([num_features], true, device)
    # Fill weight with ones for BN
    let i = 0
    while i < weight.data.len() {
        weight.data[i] = 1.0
        i = i + 1
    }
    let bias = zeros([num_features], true, device)
    
    return {
        type: "BatchNorm2d",
        weight: weight,
        bias: bias,
        num_features: num_features,
        eps: eps,
        device: device,
        training: true,
        
        forward: fn(self, input_tensor) {
            let res_data = std::math::batch_norm_2d(
                input_tensor.data, input_tensor.shape,
                self.weight.data, self.bias.data,
                self.eps, self.training
            )
            if res_data == null { return null }
            let req = input_tensor.requires_grad || self.weight.requires_grad || self.bias.requires_grad
            let ctx = null
            if req {
                ctx = { op: "batch_norm_2d", parents: [input_tensor, self.weight, self.bias], shape: input_tensor.shape }
            }
            return Tensor(res_data, input_tensor.shape, req, ctx, input_tensor.device)
        }
    }
}

fn Conv2D(in_channels, out_channels, kernel_size, stride, padding, device) {
    let weight = randn([out_channels, in_channels, kernel_size, kernel_size], true, device)
    let bias = zeros([out_channels], true, device)
    
    return {
        type: "Conv2D",
        weight: weight,
        bias: bias,
        stride: stride,
        padding: padding,
        # ...
        m_w: zeros([out_channels * in_channels * kernel_size * kernel_size]),
        v_w: zeros([out_channels * in_channels * kernel_size * kernel_size]),
        m_b: zeros([out_channels]),
        v_b: zeros([out_channels]),
        
        forward: fn(self, x) {
            return x.conv2d(self.weight, self.bias, self.stride, self.padding)
        }
    }
}

fn MaxPool2D(kernel_size, stride) {
    return {
        type: "MaxPool2D",
        kernel_size: kernel_size,
        stride: stride,
        forward: fn(self, x) {
            return x.maxpool2d(self.kernel_size, self.stride)
        }
    }
}

fn Flatten() {
    return {
        type: "Flatten",
        forward: fn(self, x) {
            return x.flatten()
        }
    }
}

fn Dropout(p) {
    return {
        type: "Dropout",
        p: p,
        training: true,
        forward: fn(self, x) {
            return x.dropout(self.p, self.training)
        }
    }
}

