import ml;
import std::df;

# --- Helper: Label Quality Checks ---

fn check_label_balance(df, label_col, threshold) {
    if threshold == null { threshold = 0.5 }
    let col = df.col(label_col)
    if col == null { return false }
    
    # Calculate counts manually or via stats if available
    let counts = {}
    let i = 0
    let n = col.len()
    while i < n {
        let val = col.get(i)
        if counts[val] == null { counts[val] = 0 }
        counts[val] = counts[val] + 1
        i = i + 1
    }
    
    let ks = std::meta::fields(counts)
    let total = n * 1.0
    let min_ratio = 1.0
    let max_ratio = 0.0
    
    let j = 0
    while j < ks.len() {
        let r = counts[ks[j]] / total
        if r < min_ratio { min_ratio = r }
        if r > max_ratio { max_ratio = r }
        j = j + 1
    }
    
    # Check if any class is too dominant
    if max_ratio / min_ratio > (1.0 / threshold) {
        println("FAIL: Class imbalance detected. Ratio: ", max_ratio / min_ratio, " (Threshold: ", 1.0/threshold, ")")
        return false
    }
    println("SUCCESS: Label distribution is balanced. Max/Min Ratio: ", max_ratio / min_ratio)
    return true
}

fn check_label_noise(df, feat_col, label_col) {
    # Detects if identical features have different labels
    let feat = df.col(feat_col)
    let label = df.col(label_col)
    
    let mapping = {}
    let i = 0
    let n = feat.len()
    let noise_count = 0
    
    while i < n {
        let fv = feat.get(i)
        let lv = label.get(i)
        
        if mapping[fv] == null {
            mapping[fv] = lv
        } else if mapping[fv] != lv {
            # println("Noise detected at row ", i, ": Feature ", fv, " has multiple labels (", mapping[fv], ", ", lv, ")")
            noise_count = noise_count + 1
        }
        i = i + 1
    }
    
    if noise_count > 0 {
        println("FAIL: Detected ", noise_count, " noisy labels (conflicting labels for identical features)")
        return false
    }
    println("SUCCESS: No conflicting labels detected")
    return true
}

# --- Test Case ---

fn test_label_quality() {
    println("--- Testing Label Quality Foundation ---")
    
    # 1. Balanced vs Imbalanced
    let balanced_col = std::df::Column("label", "int", [0, 1, 0, 1, 0, 1], null)
    let df_balanced = std::df::DataFrame([balanced_col], null)
    
    let imbalanced_col = std::df::Column("label", "int", [1, 1, 1, 1, 1, 0], null)
    let df_imbalanced = std::df::DataFrame([imbalanced_col], null)
    
    println("Checking balanced labels...")
    check_label_balance(df_balanced, "label", 0.3)
    
    println("Checking imbalanced labels...")
    check_label_balance(df_imbalanced, "label", 0.3)
    
    # 2. Noisy labels
    let feat_col = std::df::Column("feat", "int", [1, 2, 1, 3], null)
    let clean_label = std::df::Column("label", "int", [10, 20, 10, 30], null)
    let df_clean = std::df::DataFrame([feat_col, clean_label], null)
    
    let noisy_label = std::df::Column("label", "int", [10, 20, 99, 30], null) # feat=1 now has 10 AND 99
    let df_noisy = std::df::DataFrame([feat_col, noisy_label], null)
    
    println("Checking clean labels...")
    check_label_noise(df_clean, "feat", "label")
    
    println("Checking noisy labels...")
    check_label_noise(df_noisy, "feat", "label")
}

fn main() {
    test_label_quality()
}
