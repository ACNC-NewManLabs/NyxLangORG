fn leaky_relu(self, alpha) {
    if alpha == null { alpha = 0.01 }
    let res_data = std::math::leaky_relu_array(self.data, alpha)
    let ctx = null
    if self.requires_grad {
        ctx = { op: "leaky_relu", parents: [self], alpha: alpha }
    }
    return ml::tensor::Tensor(res_data, self.shape, self.requires_grad, ctx)
}

fn elu(self, alpha) {
    if alpha == null { alpha = 1.0 }
    let res_data = std::math::elu_array(self.data, alpha)
    let ctx = null
    if self.requires_grad {
        ctx = { op: "elu", parents: [self], alpha: alpha }
    }
    return ml::tensor::Tensor(res_data, self.shape, self.requires_grad, ctx)
}

