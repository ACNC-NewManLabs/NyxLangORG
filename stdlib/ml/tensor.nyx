fn abs_max(self) {
    return std::math::abs_max(self.data)
}

fn is_finite(self) {
    return std::math::is_finite(self.data)
}

fn assert_finite(self, msg) {
    if !self.is_finite() {
        println("Finite check failed: ", msg)
        exit(1)
    }
}

fn check_health(self, name) {
    let m = self.abs_max()
    if m > 1e10 || m == null {
        println("Health check failed for ", name, ": abs_max=", m)
        self.assert_finite(name)
    }
}

fn clone(self) {
    let d = [] + self.data
    return ml::tensor::Tensor(d, self.shape, self.requires_grad, self._ctx, self.device, self.strides, self.offset)
}

fn item(self) {
    if self.data.len() == 1 { return self.data[0] }
    return null
}

fn reshape(self, new_shape) {
    return ml::tensor::Tensor(self.data, new_shape, self.requires_grad, self._ctx, self.device)
}

fn transpose(self, dim0, dim1) {
    # Simple 2D transpose for now
    if self.shape.len() != 2 { return null }
    let new_shape = [self.shape[1], self.shape[0]]
    let res_data = std::math::transpose_2d(self.data, self.shape[0], self.shape[1])
    return ml::tensor::Tensor(res_data, new_shape, self.requires_grad, self._ctx, self.device)
}

fn slice(self, start_dims, end_dims) {
    let res = std::math::slice_nd(self.data, self.shape, start_dims, end_dims)
    if res == null { return null }
    return ml::tensor::Tensor(res.data, res.shape, self.requires_grad, self._ctx, self.device)
}

fn flatten(self) {
    let total = 1
    for d in self.shape { total = total * d }
    return self.reshape([total])
}

fn mean(self) {
    let sum_val = 0
    for x in self.data { sum_val = sum_val + x }
    let m = sum_val / self.data.len()
    
    let req = self.requires_grad
    let ctx = null
    if req {
        ctx = { op: "mean", parents: [self] }
    }
    return ml::tensor::Tensor([m], [1], req, ctx)
}

fn sum(self) {
    let s = 0
    for x in self.data { s = s + x }
    let req = self.requires_grad
    let ctx = null
    if req {
        ctx = { op: "sum", parents: [self] }
    }
    return ml::tensor::Tensor([s], [1], req, ctx)
}

fn backward(self, grad_output) {
    if grad_output == null {
        grad_output = ml::tensor::Tensor([1.0], [1], false)
    }
    
    if self.grad == null {
        self.grad = ml::tensor::zeros(self.shape)
    }
    
    # Simple accumulation for terminal nodes
    if self._ctx == null {
        self.grad = self.grad.add(grad_output)
        return null
    }
    
    # Dispatch to autograd engine (abstracted here for brevity, implemented higher up)
    std::math::backward(self, grad_output)
}

fn clip_grad(self, min_val, max_val) {
    if self.grad != null {
        self.grad.data = std::math::clip_array(self.grad.data, min_val, max_val)
    }
}

fn dropout(self, p, training) {
    if !training || p <= 0 { return self }
    let res = std::math::dropout(self.data, p)
    if res == null { return self }
    let res_data = res.data
    let mask = res.mask
    let req = self.requires_grad
    let ctx = null
    if req {
        ctx = { op: "dropout", parents: [self], mask: mask }
    }
    return ml::tensor::Tensor(res_data, self.shape, req, ctx, self.device)
}

fn layer_norm(self, normalized_shape, weight, bias, eps) {
    if eps == null { eps = 1e-5 }
    
    let res_data = null
    if self.device == "gpu" {
        res_data = std::math::gpu_layer_norm(self.data, self.shape, normalized_shape, weight.data, bias.data, eps)
    }
    
    if res_data == null {
        res_data = std::math::layer_norm(self.data, self.shape, normalized_shape, weight.data, bias.data, eps)
    }

    
    let req = self.requires_grad || weight.requires_grad
    if bias != null { req = req || bias.requires_grad }
    let ctx = null
    if req {
        ctx = { op: "layer_norm", parents: [self, weight, bias] }
    }
    return ml::tensor::Tensor(res_data, self.shape, req, ctx, self.device)
}

fn conv2d(self, weight, bias, stride, padding, dilation, groups) {
    if stride == null { stride = 1 }
    if padding == null { padding = 0 }
    
    let res_data = std::math::conv2d(
        self.data, self.shape, 
        weight.data, weight.shape, 
        if bias != null { bias.data } else { null },
        stride, padding
    )
    if res_data == null { return null }

    # Shape calc: [N, OC, OH, OW]
    let oh = (self.shape[2] + 2 * padding - weight.shape[2]) / stride + 1
    let ow = (self.shape[3] + 2 * padding - weight.shape[3]) / stride + 1
    let out_shape = [self.shape[0], weight.shape[0], oh, ow]

    let req = self.requires_grad || weight.requires_grad
    if bias != null { req = req || bias.requires_grad }
    let ctx = null
    if req {
        ctx = { op: "conv2d", parents: [self, weight, bias], stride: stride, padding: padding }
    }
    let dev = self.device
    if weight.device == "gpu" { dev = "gpu" }
    return ml::tensor::Tensor(res_data, out_shape, req, ctx, dev)
}

fn maxpool2d(self, kernel_size, stride, padding, dilation, ceil_mode) {
    let res = std::math::maxpool2d(self.data, self.shape, kernel_size, stride, padding, dilation, ceil_mode)
    return ml::tensor::Tensor(res.data, res.shape, self.requires_grad, self._ctx, self.device)
}

fn adaptive_avg_pool2d(self, output_size) {
    let res = std::math::adaptive_avg_pool2d(self.data, self.shape, output_size)
    return ml::tensor::Tensor(res.data, res.shape, self.requires_grad, self._ctx, self.device)
}

fn set_seed(seed) {
    ml::set_seed(seed)
}

fn _tensor_rand() {
    let arr = std::math::random_array(1)
    let val = arr[0]
    return (val + 0.1) * 5.0 + 0.0001
}

# randn: standard normal random tensor (alias for seeded_randn)
fn randn(shape, requires_grad, device) {
    if requires_grad == null { requires_grad = false }
    if device == null { device = "cpu" }
    let size = 1
    let i = 0
    while i < shape.len() {
        size = size * shape[i]
        i = i + 1
    }
    # Use Box-Muller to produce normal-distributed data from uniform
    let data = std::math::randn_array(size)
    if data == null {
        # Fallback: use random uniform (not truly normal but functional)
        data = std::math::random_array(size)
    }
    return ml::tensor::Tensor(data, shape, requires_grad, null, device)
}

fn seeded_randn(shape, requires_grad, device) {
    if requires_grad == null { requires_grad = false }
    if device == null { device = "cpu" }
    let size = 1
    let i = 0
    while i < shape.len() {
        size = size * shape[i]
        i = i + 1
    }
    let data = std::math::random_array(size)
    return ml::tensor::Tensor(data, shape, requires_grad, null, device)
}

fn zeros(shape, requires_grad, device) {
    if requires_grad == null { requires_grad = false }
    if device == null { device = "cpu" }
    let size = 1
    let i = 0
    while i < shape.len() {
        size = size * shape[i]
        i = i + 1
    }
    let data = std::math::full_array(size, 0.0)
    return ml::tensor::Tensor(data, shape, requires_grad, null, device)
}

fn ones(shape, requires_grad, device) {
    if requires_grad == null { requires_grad = false }
    if device == null { device = "cpu" }
    let size = 1
    let i = 0
    while i < shape.len() {
        size = size * shape[i]
        i = i + 1
    }
    let data = std::math::full_array(size, 1.0)
    return ml::tensor::Tensor(data, shape, requires_grad, null, device)
}
