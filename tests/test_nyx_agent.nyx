// tests/test_nyx_agent.nyx

// ── SIMD correctness tests ────────────────────────────────────────────
fn test_cosine_identical() {
    let v   = [1.0, 0.0, 0.0, 0.0];
    let sim = std::agent::cosine_similarity(v, v);
    assert(sim > 0.9999, "Identical vectors must have similarity ~1.0");
    println("[PASS] cosine_similarity: identical vectors → " + sim);
}

fn test_cosine_orthogonal() {
    let a   = [1.0, 0.0, 0.0, 0.0];
    let b   = [0.0, 1.0, 0.0, 0.0];
    let sim = std::agent::cosine_similarity(a, b);
    assert(sim < 0.001 && sim > -0.001, "Orthogonal vectors must have similarity ~0.0");
    println("[PASS] cosine_similarity: orthogonal vectors → " + sim);
}

fn test_cosine_antiparallel() {
    let a   = [1.0, 0.0];
    let b   = [-1.0, 0.0];
    let sim = std::agent::cosine_similarity(a, b);
    assert(sim < -0.999, "Anti-parallel vectors must have similarity ~-1.0");
    println("[PASS] cosine_similarity: anti-parallel vectors → " + sim);
}

// ── API contract tests ────────────────────────────────────────────────
fn test_embed_dimension() {
    let v = std::agent::embed("test");
    assert(v.len() == 384, "embed() must return 384-dimensional vector");
    println("[PASS] embed(): dimension == " + v.len());
}

fn test_embed_normalized() {
    let v    = std::agent::embed("normalization test");
    let norm = std::agent::cosine_similarity(v, v);
    assert(norm > 0.9999, "embed() output must be L2-normalized (self-sim ~1.0)");
    println("[PASS] embed(): L2-normalized → self-similarity = " + norm);
}

fn test_chunk_limit() {
    let big    = std::string::repeat("word ", 10000);  // ~50 KB
    let chunks = std::agent::text_split(big, 10);
    assert(chunks.len() <= 10000, "text_split() must not exceed 10,000 chunks");
    println("[PASS] text_split(): chunk limit enforced at " + chunks.len() + " chunks");
}

fn test_collection_lifecycle() {
    std::agent::vector_create("test_coll");
    let i0 = std::agent::vector_insert("test_coll", [1.0, 0.0, 0.0]);
    let i1 = std::agent::vector_insert("test_coll", [0.0, 1.0, 0.0]);
    let i2 = std::agent::vector_insert("test_coll", [0.0, 0.0, 1.0]);
    assert(i0 == 0 && i1 == 1 && i2 == 2, "Indices must be sequential 0,1,2");

    let q = [1.0, 0.1, 0.0];
    let r = std::agent::vector_search("test_coll", q, 1);
    assert(r[0][1] == 0, "Nearest to [1,0.1,0] should be index 0 = [1,0,0]");
    println("[PASS] collection lifecycle + search: nearest index = " + r[0][1]);
}

// ── Integration accuracy test ─────────────────────────────────────────
fn test_semantic_relevance() {
    std::agent::vector_create("sem_test");
    std::agent::vector_insert("sem_test", std::agent::embed("machine learning and AI research"));
    std::agent::vector_insert("sem_test", std::agent::embed("cooking pasta carbonara recipe"));
    std::agent::vector_insert("sem_test", std::agent::embed("deep neural network architecture"));

    let q = std::agent::embed("artificial intelligence and neural nets");
    let r = std::agent::vector_search("sem_test", q, 1);
    // Expect index 0 or 2 (both AI-related) to rank first
    assert(r[0][1] != 1, "Cooking result must NOT be the nearest to AI query");
    println("[PASS] semantic relevance: AI query → AI result (index " + r[0][1] + ")");
}

fn main() {
    println("═══ Nyx-Agent Test Suite ═══");
    test_cosine_identical();
    test_cosine_orthogonal();
    test_cosine_antiparallel();
    test_embed_dimension();
    test_embed_normalized();
    test_chunk_limit();
    test_collection_lifecycle();
    test_semantic_relevance();
    println("═══ All tests passed ✓ ═══");
}
