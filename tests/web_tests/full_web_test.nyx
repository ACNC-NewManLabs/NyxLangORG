fn str_col(n: string, l: string) -> VNode {
    let v_style = Map::new()
    v_style.insert("align-items", "center")
    v_style.insert("gap", "0.8rem")
    
    let num_style = Map::new()
    num_style.insert("color", "white")
    num_style.insert("font-size", "4.5rem")
    num_style.insert("font-weight", "900")
    num_style.insert("letter-spacing", "-0.05em")
    
    let label_style = Map::new()
    label_style.insert("color", "#00f2ff")
    label_style.insert("font-size", "1.1rem")
    label_style.insert("font-weight", "700")
    label_style.insert("letter-spacing", "0.15em")
    label_style.insert("text-transform", "uppercase")
    
    return VStack(v_style, [
        el("div", num_style, [text_node(n)]),
        el("div", label_style, [text_node(l)])
    ])
}

