/**
 * Get parent directory from path
 */
fn get_parent_dir(path: string) -> string {
    let last_slash = -1;
    let i = 0;
    while i < len(path) {
        let c = char_at(path, i);
        if c == "/" {
            last_slash = i;
        }
        i = i + 1;
    }
    
    if last_slash <= 0 {
        return "";
    }
    
    return substring(path, 0, last_slash);
}

