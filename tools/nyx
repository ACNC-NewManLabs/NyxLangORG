#!/usr/bin/env bash
# Nyx Toolchain Redirector
# This script bridges the legacy entry point to the new high-performance Rust CLI.

set -euo pipefail

# Find the repository root
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Run the new Nyx CLI
exec cargo run --quiet --manifest-path "$REPO_ROOT/tools/cli/Cargo.toml" --bin nyx -- "$@"
