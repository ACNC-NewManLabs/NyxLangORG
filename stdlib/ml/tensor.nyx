# Nyx Standard Library: ML Tensor
# High-performance tensor operations wrapping native Rust kernels
# Note: Methods return raw {data, shape} objects to avoid recursive constructor calls

fn Tensor(data, shape, requires_grad, _ctx, device, strides, offset) {
    if shape == null { println("DEBUG: Tensor() called with Null shape!") }
    if requires_grad == null { requires_grad = false }
    if device == null { device = "cpu" }
    
    if strides == null {
        # Default: row-major strides
        let s = []
        let current_stride = 1
        let i = shape.len() - 1
        while i >= 0 {
            s.push(current_stride)
            current_stride = current_stride * shape[i]
            i = i - 1
        }
        # Reverse to get [dim0_stride, dim1_stride, ...]
        strides = []
        let j = s.len() - 1
        while j >= 0 {
            strides.push(s[j])
            j = j - 1
        }
    }
    if offset == null { offset = 0 }

    return {
        data: data,
        shape: shape,
        strides: strides,
        offset: offset,
        requires_grad: requires_grad,
        grad: null,
        _ctx: _ctx,
        device: device,
        
        move_to: move_to,
        matmul_gpu: matmul_gpu,
        matmul: matmul,
        matmul_bias: matmul_bias,
        matmul_fused: matmul_fused,
        softmax: softmax,
        add: add,
        sub: sub,
        mul: mul,
        div: div,
        relu: relu,
        exp: exp,
        fma: fma,
        tanh: tanh,
        sigmoid: sigmoid,
        leaky_relu: leaky_relu,
        elu: elu,
        gelu: gelu,
        hardswish: hardswish,
        hardsigmoid: hardsigmoid,
        mish: mish,
        abs_max: abs_max,
        is_finite: is_finite,
        assert_finite: assert_finite,
        check_health: check_health,
        clone: clone,
        item: item,
        reshape: reshape,
        transpose: transpose,
        slice: slice,
        flatten: flatten,
        mean: mean,
        sum: sum,
        backward: backward,
        clip_grad: clip_grad,
        dropout: dropout,
        layer_norm: layer_norm,
        conv2d: conv2d,
        maxpool2d: maxpool2d,
        adaptive_avg_pool2d: adaptive_avg_pool2d,
    }
}

fn move_to(self, new_device) {
    if self.device == new_device { return self }
    if new_device == "gpu" {
        let res = std::math::to_gpu(self.data, self.shape)
        if res != null { self.data = res }
    } else {
        let res = std::math::to_cpu(self.data)
        if res != null { self.data = res }
    }
    self.device = new_device
    return self
}

fn matmul(self, weights) {
    let res_data = std::math::matmul(
        self.data, self.shape[0], self.shape[1],
        weights.data, weights.shape[0], weights.shape[1]
    )
    if res_data == null { return null }
    let out_shape = [self.shape[0], weights.shape[1]]
    let req = self.requires_grad || weights.requires_grad
    let ctx = null
    if req {
        ctx = { op: "matmul", parents: [self, weights] }
    }
    let dev = self.device
    if weights.device == "gpu" { dev = "gpu" }
    return ml::tensor::Tensor(res_data, out_shape, req, ctx, dev)
}
 
fn matmul_gpu(self, weights) {
    let res_data = std::math::matmul_gpu(
        self.data, self.shape[0], self.shape[1],
        weights.data, weights.shape[1]
    )
    if res_data == null { return null }
    let out_shape = [self.shape[0], weights.shape[1]]
    let req = self.requires_grad || weights.requires_grad
    let ctx = null
    if req {
        ctx = { op: "matmul_gpu", parents: [self, weights] }
    }
    return ml::tensor::Tensor(res_data, out_shape, req, ctx, "gpu")
}

fn matmul_bias(self, weights, bias) {
    # fused matmul + bias add in one operation
    let res_data = std::math::matmul_bias(
        self.data, self.shape[0], self.shape[1],
        weights.data, weights.shape[0], weights.shape[1],
        bias.data
    )
    if res_data == null {
        # fallback: matmul then add
        let h = self.matmul(weights)
        if h == null { return null }
        return h.add(bias)
    }
    let out_shape = [self.shape[0], weights.shape[1]]
    let req = self.requires_grad || weights.requires_grad || bias.requires_grad
    let ctx = null
    if req {
        ctx = { op: "matmul_bias", parents: [self, weights, bias] }
    }
    let dev = self.device
    if weights.device == "gpu" { dev = "gpu" }
    return ml::tensor::Tensor(res_data, out_shape, req, ctx, dev)
}

fn matmul_fused(self, weights, bias) {
    let res_data = std::math::matmul_bias(
        self.data, self.shape[0], self.shape[1],
        weights.data, weights.shape[0], weights.shape[1],
        bias.data
    )
    if res_data == null { return null }
    let out_shape = [self.shape[0], weights.shape[1]]
    let req = self.requires_grad || weights.requires_grad || bias.requires_grad
    let ctx = null
    if req {
        ctx = { op: "matmul_fused", parents: [self, weights, bias] }
    }
    let dev = self.device
    if weights.device == "gpu" { dev = "gpu" }
    return ml::tensor::Tensor(res_data, out_shape, req, ctx, dev)
}


fn softmax(self) {
    # std::math::softmax_native takes [data, rows]
    # If 2D, rows = shape[0]. If 1D, rows = 1.
    let rows = 1
    if self.shape.len() > 1 { rows = self.shape[0] }
    
    let res_data = std::math::softmax(self.data, rows)
    if res_data == null { return null }
    
    let req = self.requires_grad
    let ctx = null
    if req {
        ctx = { op: "softmax", parents: [self] }
    }
    return ml::tensor::Tensor(res_data, self.shape, req, ctx, self.device)
}

fn add(self, other) {
    if self.device == "gpu" || other.device == "gpu" {
        let len = self.shape[0] * self.shape[1]
        let res_data = std::math::gpu_elementwise(self.data, other.data, 0, len) # 0: add
        let req = self.requires_grad || other.requires_grad
        let ctx = null
        if req { ctx = { op: "add", parents: [self, other] } }
        return ml::tensor::Tensor(res_data, self.shape, req, ctx, "gpu")
    }
    let res = std::math::add_broadcast(self.data, self.shape, other.data, other.shape)
    if res == null { return null }
    let req = self.requires_grad || other.requires_grad
    let ctx = null
    if req {
        ctx = { op: "add", parents: [self, other] }
    }
    return ml::tensor::Tensor(res.data, res.shape, req, ctx)
}

fn mul(self, other) {
    if std::meta::typeof(other) == "number" {
        let res_data = std::math::mul_scalar(self.data, other)
        return ml::tensor::Tensor(res_data, self.shape, self.requires_grad, null, self.device)
    }
    if self.device == "gpu" || other.device == "gpu" {
        let len = self.shape[0] * self.shape[1]
        let res_data = std::math::gpu_elementwise(self.data, other.data, 1, len) # 1: mul
        let req = self.requires_grad || other.requires_grad
        let ctx = null
        if req { ctx = { op: "mul", parents: [self, other] } }
        return ml::tensor::Tensor(res_data, self.shape, req, ctx, "gpu")
    }
    let res = std::math::mul_broadcast(self.data, self.shape, other.data, other.shape)
    if res == null { return null }
    let req = self.requires_grad || other.requires_grad
    let ctx = null
    if req {
        ctx = { op: "mul", parents: [self, other] }
    }
    return ml::tensor::Tensor(res.data, res.shape, req, ctx)
}

fn relu(self) {
    let res_data = std::math::relu_array(self.data)
    if res_data == null { return null }
    let ctx = null
    if self.requires_grad {
        ctx = { op: "relu", parents: [self] }
    }
    return ml::tensor::Tensor(res_data, self.shape, self.requires_grad, ctx, self.device)
}

fn exp(self) {
    if self.device == "gpu" {
        let len = self.shape[0] * self.shape[1]
        let res_data = std::math::gpu_elementwise(self.data, self.data, 3, len) # 3: exp
        let ctx = null
        if self.requires_grad { ctx = { op: "exp", parents: [self] } }
        return ml::tensor::Tensor(res_data, self.shape, self.requires_grad, ctx, "gpu")
    }
    let res_data = std::math::exp_array(self.data)
    let ctx = null
    if self.requires_grad {
        ctx = { op: "exp", parents: [self] }
    }
    return ml::tensor::Tensor(res_data, self.shape, self.requires_grad, ctx)
}

fn fma(self, b, c) {
    if self.device == "gpu" || b.device == "gpu" || c.device == "gpu" {
        let len = self.shape[0] * self.shape[1]
        let res_data = std::math::gpu_fma(self.data, b.data, c.data, len)
        let req = self.requires_grad || b.requires_grad || c.requires_grad
        let ctx = null
        if req { ctx = { op: "fma", parents: [self, b, c] } }
        return ml::tensor::Tensor(res_data, self.shape, req, ctx, "gpu")
    }
    # Fallback to a + b * c
    return self.add(b.mul(c))
}
fn sub(self, other) {
    let res = std::math::sub_broadcast(self.data, self.shape, other.data, other.shape)
    if res == null { return null }
    let req = self.requires_grad || other.requires_grad
    let ctx = null
    if req {
        ctx = { op: "sub", parents: [self, other] }
    }
    return ml::tensor::Tensor(res.data, res.shape, req, ctx)
}

fn div(self, other) {
    let res = std::math::div_broadcast(self.data, self.shape, other.data, other.shape)
    if res == null { return null }
    let req = self.requires_grad || other.requires_grad
    let ctx = null
    if req {
        ctx = { op: "div", parents: [self, other] }
    }
    return ml::tensor::Tensor(res.data, res.shape, req, ctx)
}

