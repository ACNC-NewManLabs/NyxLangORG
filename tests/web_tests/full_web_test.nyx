// Huge Native UI Experience for Nyx Web Engine
// Built natively, without raw HTML strings mapped manually.

mod server
mod router
mod middleware
mod api
mod realtime
mod security

// --- NATIVE UI VIRTUAL DOM PRIMITIVES ---

struct VNode {
    tag: string
    styles: Map<string, string>
    attrs: Map<string, string>
    children: List<VNode>
    text: string
}

fn el(tag: string, styles: Map<string, string>, children: List<VNode>) -> VNode {
    return VNode {
        tag: tag
        styles: styles
        attrs: Map::new()
        children: children
        text: ""
    }
}

fn text_node(t: string) -> VNode {
    return VNode {
        tag: ""
        styles: Map::new()
        attrs: Map::new()
        children: List::new()
        text: t
    }
}

// Layout Primitives (Flex & CSS Grid)
fn VStack(styles: Map<string, string>, children: List<VNode>) -> VNode {
    styles.insert("display", "flex")
    styles.insert("flex-direction", "column")
    return el("div", styles, children)
}

fn HStack(styles: Map<string, string>, children: List<VNode>) -> VNode {
    styles.insert("display", "flex")
    styles.insert("flex-direction", "row")
    return el("div", styles, children)
}

fn Grid(styles: Map<string, string>, children: List<VNode>) -> VNode {
    styles.insert("display", "grid")
    return el("div", styles, children)
}

// Interactive & Media Primitives
fn Link(url: string, styles: Map<string, string>, children: List<VNode>) -> VNode {
    let node = el("a", styles, children)
    node.attrs.insert("href", url)
    return node
}

fn Image(url: string, styles: Map<string, string>) -> VNode {
    let node = el("img", styles, List::new())
    node.attrs.insert("src", url)
    return node
}

// Universal DOM Compiler (Nyx UI -> HTML string chunks)
fn render_node(node: VNode) -> string {
    if node.text != "" { return node.text }
    
    let style_str = ""
    for k in node.styles.keys() { 
        style_str = style_str + k + ":" + node.styles.get(k) + ";" 
    }
    
    let attr_str = ""
    for k in node.attrs.keys() { 
        attr_str = attr_str + " " + k + "='" + node.attrs.get(k) + "'" 
    }
    
    let html = "<" + node.tag + attr_str
    if style_str != "" { html = html + " style='" + style_str + "'" }
    html = html + ">"
    
    for child in node.children { 
        html = html + render_node(child) 
    }
    
    return html + "</" + node.tag + ">"
}

// --- MEGA COMPONENT TREE ---

fn NavBar() -> VNode {
    let nav_style = css`
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        padding: 1rem 3rem;
        background: rgba(10, 10, 15, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        z-index: 100;
        justify-content: space-between;
        align-items: center;
    `

    let logo_style = css`
        color: white;
        font-size: 1.8rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        text-decoration: none;
    `

    let links_style = css`
        gap: 2.5rem;
        align-items: center;
    `

    let link_style = css`
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: color 0.2s;
    `

    let btn_style = css`
        padding: 0.8rem 1.8rem;
        background: white;
        color: black;
        border-radius: 99px;
        font-size: 0.95rem;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 10px 20px rgba(255,255,255,0.1);
    `

    return HStack(nav_style, [
        Link("/", logo_style, [text_node("Nyx.")]),
        HStack(links_style, [
            Link("#capabilities", link_style, [text_node("Capabilities")]),
            Link("#ecosystem", link_style, [text_node("Ecosystem")]),
            Link("#docs", link_style, [text_node("Documentation")]),
            Link("#download", btn_style, [text_node("Get Engine")])
        ])
    ])
}

